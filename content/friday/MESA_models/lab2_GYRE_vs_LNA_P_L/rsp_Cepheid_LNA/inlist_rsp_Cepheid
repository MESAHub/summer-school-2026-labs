
&star_job

      show_log_description_at_start = .false.
      create_RSP_model = .true.
      
/ ! end of star_job namelist

&eos
/ ! end of eos namelist

&kap 
   Zbase = 0.002d0 ! Keep same Zbase as lab 1
/ ! end of kap namelist

&colors
/ ! end of colors namelist

&controls
! Set parameters to build RSP envelope 
    x_character_ctrl(10) = 'RSP_test_grid_out.dat'
    ! Change these parameters 
    RSP_mass = 7.84
    RSP_Teff = 4150.50
    RSP_L = 17020.96

    ! Fixed to match initial values from lab 1 
    RSP_X = 0.7440d0
    RSP_Z = 0.002d0

    ! Set to zero to perform only LNA, otherwise RSP will do non-linear evolution 
    RSP_max_num_periods = 0 


! solver
   use_gold2_tolerances = .true.

! output controls

      photo_interval = 1000
      profile_interval = 4000
      history_interval = 10
      terminal_interval = 100

/ ! end of controls namelist



&pgstar
/ ! end of pgstar namelist
