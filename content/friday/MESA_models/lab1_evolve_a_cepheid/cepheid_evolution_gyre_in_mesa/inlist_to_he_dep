
&star_job

   save_model_when_terminate = .true.
   save_model_filename = 'he_dep.mod'
   required_termination_code_string = ''

   ! if you'd like to evolve with a relaxed atmosphere.
   relax_to_this_tau_factor = 1d-3
   dlogtau_factor = 0.1d0
   relax_tau_factor = .false.

   ! instead of create_pre-ms, we relax a zams model.
   ! when we relax from pre-ms model, default z_frac = 3, gs98.
   relax_initial_Z = .true.
   new_Z = 2d-3
   relax_initial_Y = .true.
   new_Y = 0.2545
   create_pre_main_sequence_model = .false. ! load from ZAMS and relax Z
   initial_zfracs = 3

   pgstar_flag = .true.
/ !end of star_job namelist

&kap

   kap_file_prefix = 'gs98'    ! 'gs98' 'a09'  'OP_a09' 'OP_gs98'
   kap_CO_prefix   = 'gs98_co' ! 'gs98_co' 'a09_co'
   use_Type2_opacities = .true.
   Zbase = 0.002d0
   kap_lowT_prefix = 'lowT_fa05_gs98'
   cubic_interpolation_in_X = .false.
   cubic_interpolation_in_Z = .false.

/

&eos
/

&controls

   initial_mass = 8.5d0
   !initial_Y = 0.267d0
   !initial_Z = 0.003d0


! GYRE output controls
   !write_pulse_data_with_profile = .true.
   pulse_data_format = 'GYRE'

   x_logical_ctrl(37) = .true. ! if true, then run GYRE

   x_integer_ctrl(1) = 10 ! output GYRE info at this step interval
   x_logical_ctrl(1) = .false. ! save GYRE info whenever save profile

   x_integer_ctrl(2) = 3 ! max number of modes to output per call
   x_logical_ctrl(2) = .false. ! output eigenfunction files

   x_integer_ctrl(3) = 0 ! mode l (e.g. 0 for p modes, 1 for g modes)
      ! should match gyre.in mode l
   x_integer_ctrl(4) = 1 ! order
   x_ctrl(1) = 0.158d-05 ! freq ~ this (Hz)
   x_ctrl(2) = 0.33d+03 ! growth < this (days)


! stop when the center mass fraction of h1 drops below this limit
    xa_central_lower_limit_species(1) = 'he4'
    xa_central_lower_limit(1) = 1d-8


! see run_star_extras for stopping condition
   when_to_stop_rtol = 1d-3
   when_to_stop_atol = 1d-3
   !max_model_number = 1970

! convection controls
    steps_before_use_TDC = 0
    MLT_option = 'TDC'
    include_mlt_corr_to_TDC = .false.
    mixing_length_alpha = 1.77d0
    use_ledoux_criterion = .true.
    alpha_semiconvection = 1d0
    thermohaline_coeff = 0d0

! wind model section: ! for M < 10
   cool_wind_full_on_T    = 9.99d9
   hot_wind_full_on_T     = 1d10
   cool_wind_RGB_scheme   = 'Reimers'
   cool_wind_AGB_scheme   = 'Blocker'
   RGB_to_AGB_wind_switch = 1d-4
   Reimers_scaling_factor = 0.5   ! 0.1
   Blocker_scaling_factor = 0.5   ! 0.5  crank up to 1.0 when the mass loss stops and/or timestep crashes

! overshoot controls
! we only include a bit of exponential overshooting to smooth things out

   overshoot_scheme(1) = 'exponential'
   overshoot_zone_type(1) = 'any'
   overshoot_zone_loc(1) = 'any'
   overshoot_bdy_loc(1) = 'any'
   overshoot_f(1) = 0.02
   overshoot_f0(1) = 0.002

   !overshoot_scheme(2) = 'exponential'
   !overshoot_zone_type(2) = 'nonburn'
   !overshoot_zone_loc(2) = 'any'
   !overshoot_bdy_loc(2) = 'bottom'
   !overshoot_f(2) = 0.04!4
   !overshoot_f0(2) = 0.002

! solver controls
   make_gradr_sticky_in_solver_iters = .true.

!timestep and mesh

 time_delta_coeff = 1.5d0
 mesh_delta_coeff = 1d0


! output
   log_directory = 'LOGS_evolution'

   photo_digits = 8
   photo_interval = 100

   profile_interval = 999999         ! sofia: was 200

   history_interval = 5              ! sofia: was 1
   terminal_interval = 10
   max_num_profile_models = 1000000 ! 100 ! RECOMMENDED 10000


   num_trace_history_values = 2
   trace_history_value_name(1) = 'log_rel_run_E_err'
   trace_history_value_name(2) = 'rel_E_err'
   warn_when_large_rel_run_E_err = 1d-2

 ! debugging
   report_solver_progress = .false.

/ ! end of controls namelist

&pgstar

Grid1_file_dir = 'png_evolution'
History_Track1_file_flag = .false.
History_Track2_file_flag = .false.

 pgstar_interval = 10

 History_Panels1_xaxis_name = 'model_number'
 History_Panels1_max_width = -1

 Profile_Panels3_xaxis_name = 'mass'
 Profile_Panels3_xaxis_reversed = .false.

 TRho_Profile_xmin = -12.0
 TRho_Profile_xmax = 7d0!5d0!10.0
 TRho_Profile_ymin = 2.5
 TRho_Profile_ymax = 9d0!8.5d0!10.0

/ ! end of pgstar namelist
